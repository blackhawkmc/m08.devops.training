pipeline {
    agent none

    stages {
        stage('Parallel Jobs') {
            parallel {
                stage('Agent 1') {
                    agent { label 'agent-01' }
                    steps {
                        echo "Running on agent-01: ${env.NODE_NAME}"
                        sh 'echo "Job A on agent-01"'
                    }
                }
                stage('Agent 2') {
                    agent { label 'agent-02' }
                    steps {
                        echo "Running on agent-02: ${env.NODE_NAME}"
                        sh 'echo "Job B on agent-02"'
                    }
                }
                stage('Agent 3') {
                    agent { label 'agent-03' }
                    steps {
                        echo "Running on agent-03: ${env.NODE_NAME}"
                        sh 'echo "Job C on agent-03"'
                    }
                }
                stage('Agent 4') {
                    agent { label 'agent-04' }
                    steps {
                        echo "Running on agent-04: ${env.NODE_NAME}"
                        sh 'echo "Job D on agent-04"'
                    }
                }
                stage('Agent 5') {
                    agent { label 'agent-05' }
                    steps {
                        echo "Running on agent-05: ${env.NODE_NAME}"
                        sh 'echo "Job E on agent-05"'
                    }
                }

            }
        }

        stage('Collect Results') {
            agent any
            steps {
                echo "Back on master/any agent: ${env.NODE_NAME}"
            }
        }
    }
}
